{
  "expert": {
    "command": "expert",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".ex": "elixir",
      ".exs": "elixir",
      ".heex": "phoenix-heex",
      ".leex": "elixir"
    },
    "restartOnCrash": true,
    "maxRestarts": 3,
    "startupTimeout": 60000,
    "shutdownTimeout": 5000
  }
}